# ── FLASK ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-minimum-32-chars
FLASK_ENV=production

# ── SITE ──────────────────────────────────────────────────────────────────────
SITE_URL=https://your-app.onrender.com
ALLOWED_ORIGINS=https://your-app.onrender.com

# ── SUPABASE ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your_supabase_service_role_key

# ── WEB SEARCH ────────────────────────────────────────────────────────────────
# SUNAI uses a two-tier search system:
#
#   Tier 1 — Serper.dev (Google Search results)
#     • Best quality results
#     • Free: 2 500 queries/month → https://serper.dev → Dashboard → API Key
#     • Set SERPER_API_KEY below to enable
#     • If left blank, falls through to DuckDuckGo automatically
#
#   Tier 2 — DuckDuckGo (free fallback, NO key needed)
#     • Completely free, no sign-up required
#     • Activated automatically when Serper key is missing OR Serper returns empty
#     • No extra configuration needed — works out of the box
#
SERPER_API_KEY=your_serper_api_key_here   # leave blank to use DuckDuckGo only

# ── AI APIs ───────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Extra free LLM providers (fallback chain) ─────────────────────────────────
# Cerebras: free 1M tokens/day, fastest inference → https://cloud.cerebras.ai
# Leave blank to skip (DuckDuckGo AI is always available with no key needed)
CEREBRAS_API_KEY=   # get free key at cloud.cerebras.ai → API Keys

# ── RAZORPAY ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── GOOGLE OAUTH (v4.1) ───────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx

# ── EMAIL / SMTP (v4.1 - for verification & password reset) ───────────────────
# Use Gmail App Password or SendGrid / Resend SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here
FROM_NAME=SUNAI

# ── ADMIN ─────────────────────────────────────────────────────────────────────
# Comma-separated emails that get admin role automatically on register
ADMIN_EMAILS=admin@yourdomain.com

# ── REDIS (v5.0 - optional, for rate limiting in production) ──────────────────
# Leave empty to use in-memory (fine for single instance)
# REDIS_URL=redis://default:password@your-redis-host:6379
